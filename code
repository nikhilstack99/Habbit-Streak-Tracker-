import os

FILE = "habits.txt"

def load_habits():
    habits = {}

    if os.path.exists(FILE):
        with open(FILE, "r") as f:
            for line in f:
                name, streak = line.strip().split(",")
                habits[name] = int(streak)

    return habits


def save_habits(habits):
    with open(FILE, "w") as f:
        for name, streak in habits.items():
            f.write(f"{name},{streak}\n")


def add_habit(habits):
    name = input("Enter habit name: ")

    if name in habits:
        print("Habit already exists.")
    else:
        habits[name] = 0
        print("Habit added!")


def complete_habit(habits):
    name = input("Enter habit name: ")

    if name in habits:
        habits[name] += 1
        print("Great job! Streak increased.")
    else:
        print("Habit not found.")


def view_habits(habits):
    if not habits:
        print("No habits added yet.")
        return

    print("\nYour Habits:")
    for name, streak in habits.items():
        print(f"{name} -> {streak} day streak")


def main():
    habits = load_habits()

    while True:
        print("\n=== Habit Streak Tracker ===")
        print("1. Add Habit")
        print("2. Complete Habit")
        print("3. View Habits")
        print("4. Exit")

        choice = input("Choose: ")

        if choice == "1":
            add_habit(habits)

        elif choice == "2":
            complete_habit(habits)

        elif choice == "3":
            view_habits(habits)

        elif choice == "4":
            save_habits(habits)
            print("Data saved. Goodbye!")
            break

        else:
            print("Invalid choice.")


main()
